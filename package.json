{
  "name": "minted-panel-workbench",
  "private": true,
  "version": "0.1.0",
  "description": "Minted Panel Chrome extension — one-click payer portal form fill from provider data via the Minted Panel API.",
  "type": "module",
  "scripts": {
    "build": "vite build && vite build --config vite.content.config.ts",
    "watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "eslint": "^10.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
